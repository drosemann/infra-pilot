# Infra Pilot - Environment Configuration Template
#
# Copy this file to .env and fill in your configuration values
# DO NOT commit .env to version control

# ============================================
# Application Settings
# ============================================

# Environment (development/staging/production)
NODE_ENV=development

# Application host and port (for local development)
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================================
# Discord Service Configuration
# ============================================

# See services/discord-service/.env.example for Discord-specific variables
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_SERVICE_DISABLED=true
ORCHESTRATOR_AGENT_DISABLED=true
PTERODACTYL_API_URL=https://your-pterodactyl-panel.com/api
PTERODACTYL_API_KEY=your_api_key_here

# ============================================
# Database Configuration
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/infra_pilot
POSTGRES_USER=infra_pilot
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=infra_pilot

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379

# ============================================
# Service Core (Java) Configuration  
# ============================================

# Java application settings
JAVA_OPTS=-Xmx512m -Xms256m
SPRING_PROFILES_ACTIVE=dev

# ============================================
# Orchestrator Agent (Python) Configuration
# ============================================

# Python service settings
LOG_LEVEL=INFO
DEBUG=false

# ============================================
# Management Panel (Frontend) Configuration
# ============================================

# React/Vite settings
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# Service-to-service URLs used by integration and deployment flows
DASHBOARD_URL=http://localhost:5173
DISCORD_API_URL=http://localhost:3001
SERVICE_CORE_URL=http://localhost:8080
ORCHESTRATOR_URL=http://orchestrator-agent:8500
INTEGRATION_API_URL=http://localhost:9000

# ============================================
# Docker Compose
# ============================================

ORCHESTRATOR_WEBHOOK_PORT=8500

DISCORD_WEBHOOK_PORT=3002

MANAGEMENT_BACKEND_PORT=3001

MANAGEMENT_FRONTEND_PORT=5173

REDIS_PORT=6379

POSTGRES_PORT=5432

# Image registry (for Docker builds)
REGISTRY=ghcr.io
IMAGE_TAG=latest

# ============================================
# Monitoring & Logging
# ============================================

# Sentry error tracking (optional)
SENTRY_DSN=

# Log aggregation (optional)
LOKI_URL=

# ============================================
# Security
# ============================================

# API authentication
JWT_SECRET=your_jwt_secret_key_here

# CORS settings
CORS_ORIGIN=http://localhost:3000

# ============================================
# Notes
# ============================================

# 1. Service-specific environment variables are documented in:
#    - services/discord-service/.env.example
#    - services/orchestrator-agent/.env.example
#    - services/management-panel/.env.example
#    - services/service-core/application.yml

# 2. For production, use a secrets management tool (AWS Secrets Manager, etc.)

# 3. Never commit actual credentials - use .env.example templates

# 4. Run services with: docker-compose up -d
#    Or locally: ./scripts/setup.sh

# Infra Pilot - Environment Configuration
# Copy to .env and fill in your values

# ============================================
# Application
# ============================================
NODE_ENV=development
APP_VERSION=dev

# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=infra_pilot
POSTGRES_PASSWORD=infra_pilot_dev_password
POSTGRES_DB=infra_pilot
POSTGRES_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# Management Panel
# ============================================
PORT=3001
MANAGEMENT_BACKEND_PORT=3001
MANAGEMENT_FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3001
VITE_ENVIRONMENT=development
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=local-dev-anon-key
JWT_SECRET=infra-pilot-local-dev-secret

# ============================================
# Orchestrator Agent (profile: discord)
# ============================================
DISCORD_BOT_TOKEN=
LOG_LEVEL=INFO

# ============================================
# Discord Service (profile: discord)
# ============================================
DISCORD_TOKEN=
PTERODACTYL_API_URL=http://localhost:8080/api
PTERODACTYL_API_KEY=local-dev-key
SERVER_CREATION_CHANNEL_ID=
LOCATION_ID=1
MAX_SERVERS_PER_USER=1

# ============================================
# Orchestrator Ports
# ============================================
ORCHESTRATOR_WEBHOOK_PORT=8500
DISCORD_WEBHOOK_PORT=3002

# Infra Pilot - Environment Configuration Template
#
# Copy this file to .env and fill in your configuration values
# DO NOT commit .env to version control
#
# Required = must be set; Optional = falls back to default

# ============================================
# Application Settings
# ============================================

# Environment (development/staging/production)
NODE_ENV=development
# Application host and port
APP_HOST=0.0.0.0
APP_PORT=8000
# Debug mode
DEBUG=false
# App version identifier (shown in UI)
APP_VERSION=dev
# Public IP for externally reachable services
PUBLIC_IP=
# Host IP for container-to-container communication
HOST_IP=127.0.0.1

# ============================================
# Discord Service
# ============================================

# Discord bot tokens (DISCORD_TOKEN used by discord-service, DISCORD_BOT_TOKEN by orchestrator)
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# Set to "true" to disable the service without removing config
DISCORD_SERVICE_DISABLED=true
ORCHESTRATOR_AGENT_DISABLED=true
# Discord channel/role IDs
SERVER_CREATION_CHANNEL_ID=your_channel_id_here
SERVER_CREATOR_ROLE_ID=your_role_id_here
WORKFLOW_NOTIFICATION_CHANNEL_ID=your_channel_id_here
SESSION_ALERT_CHANNEL_ID=your_channel_id_here
COMPLIANCE_ALERT_CHANNEL_ID=your_channel_id_here
# Max servers a user can create
MAX_SERVERS_PER_USER=1

# ============================================
# Pterodactyl Panel
# ============================================

PTERODACTYL_API_URL=https://your-pterodactyl-panel.com/api
PTERODACTYL_API_KEY=your_api_key_here
# Default location/node ID for deployments
LOCATION_ID=1
# Pterodactyl Egg IDs for each service type
MINECRAFT_EGG_ID=1
NODEJS_EGG_ID=2
TEAMSPEAK_EGG_ID=3
DATABASE_EGG_ID=4
PYTHON_EGG_ID=5

# ============================================
# PostgreSQL Database
# ============================================

# Full connection string (overrides individual PG* vars below)
DATABASE_URL=postgresql://user:password@localhost:5432/infra_pilot
POSTGRES_USER=infra_pilot
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=infra_pilot
POSTGRES_PORT=5432
# Alternative postgres vars (used by seed scripts and some services)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=infra_pilot
PG_CONNECTION_STRING=

# ============================================
# MySQL / MariaDB (used by orchestrator-agent)
# ============================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=infra_pilot

# ============================================
# Redis (caching / sessions / message queue)
# ============================================

REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ============================================
# Service Core (Java / Spring Boot)
# ============================================

JAVA_OPTS=-Xmx512m -Xms256m
SPRING_PROFILES_ACTIVE=dev

# ============================================
# Orchestrator Agent (Python)
# ============================================

LOG_LEVEL=INFO
# Comma-separated whitelisted user/server IDs
WHITELIST_IDS=
# Cuttly URL shortener API key (optional)
CUTTLY_API_KEY=
# CurseForge API key (for modpack installer)
CURSEFORGE_API_KEY=
# SSL certificate email for automated certs
SSL_EMAIL=admin@example.com

# ============================================
# Integration Service
# ============================================

INTEGRATION_SERVICE_URL=http://localhost:9000
INTEGRATION_API_URL=http://localhost:9000
WEBHOOK_SECRET=change-me-webhook-secret
IPAAS_WEBHOOK_SECRET=change-me-ipaas-secret
SECRETS_ENCRYPTION_KEY=
# HashiCorp Vault (optional)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# ============================================
# Management Panel (Node.js Backend)
# ============================================

PORT=3001
MANAGEMENT_BACKEND_PORT=3001
MANAGEMENT_FRONTEND_PORT=5173
DASHBOARD_URL=http://localhost:5173

# ============================================
# Management Panel (Vite / React Frontend)
# ============================================

VITE_API_URL=http://localhost:3001
VITE_ENVIRONMENT=development
VITE_DEMO_FEATURE_ENABLED=false
# Supabase (optional local or hosted)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=local-dev-anon-key
# Crowdin OTA translations (optional)
VITE_CROWDIN_OTA_URL=
VITE_CROWDIN_DISTRIBUTION_HASH=

# ============================================
# Service-to-Service URLs
# ============================================

DISCORD_API_URL=http://localhost:3001
SERVICE_CORE_URL=http://localhost:8080
ORCHESTRATOR_URL=http://localhost:8500
CLI_API_URL=http://localhost:8080
IPILOT_API_URL=http://localhost:8080

# ============================================
# Webhooks & Ports
# ============================================

ORCHESTRATOR_WEBHOOK_PORT=8500
DISCORD_WEBHOOK_PORT=3002
CODE_REVIEW_WEBHOOK_PORT=3000
GITOPS_WEBHOOK_PORT=8500
DISCORD_WEBHOOK=
CODE_REVIEW_WEBHOOK_SECRET=default-secret

# ============================================
# AI / Code Review
# ============================================

AI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4
GITHUB_TOKEN=

# ============================================
# OpenTelemetry / Monitoring
# ============================================

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
LOKI_URL=

# ============================================
# Prometheus & Grafana
# ============================================

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================
# Security
# ============================================

# JWT signing secret (REQUIRED - change for production)
JWT_SECRET=your_jwt_secret_key_here
# CORS allowed origin
CORS_ORIGIN=http://localhost:3000

# ============================================
# Docker / Container Registry
# ============================================

REGISTRY=ghcr.io
IMAGE_TAG=latest
REGISTRY_DOCKERHUB=docker.io

# ============================================
# Mobile App (Expo / React Native)
# ============================================

EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_WS_URL=ws://localhost:3001

# ============================================
# Infrastructure & Advanced
# ============================================

# Override path for provider config (testing)
PROVIDER_CONFIG_OVERRIDE=
# Test environment label
TEST_ENV=local
# VPS configuration
VPS_INSTANCES_FILE=vps_instances.json
DATABASE_FILE=database.txt
DEFAULT_IMAGE=ubuntu-22.04-with-tmate
RAM_LIMIT=1g
SERVER_LIMIT=1
# Kubernetes
K8S_NETWORK=k3s-net
K8S_DATA_DIR=data/k8s_clusters.json
# Edge / FaaS
EDGE_DATA_FILE=data/edge_nodes.json
FAAS_DATA_FILE=data/faas_functions.json
# Disaster Recovery
DR_PLANS_FILE=data/dr_plans.json
DR_DRILL_INTERVAL_HOURS=24
RTO_TARGET_SECONDS=300
RPO_TARGET_SECONDS=3600
# Runbooks
RUNBOOKS_FILE=data/runbooks.json
RUNBOOK_CHECK_INTERVAL_SECONDS=60
# Security scanning
SCAN_RESULTS_FILE=data/scan_results.json
SCAN_INTERVAL_HOURS=6
SCAN_POLICY_DEFAULT_SEVERITY=CRITICAL
SCAN_POLICY_DEFAULT_ACTION=block
# Cloud pricing
CLOUD_PRICING_DATA_FILE=data/cloud_pricing.json
# Synthetic monitoring
SYNTHETIC_CHECKS_FILE=data/synthetic_checks.json
SYNTHETIC_CHECK_INTERVAL_MINUTES=5

# ============================================
# Notes
# ============================================

# 1. Service-specific variables are documented in:
#    - services/discord-service/.env.example
#    - services/orchestrator-agent/.env.example  (not yet created)
#    - services/management-panel/.env.example     (not yet created)
#
# 2. For production, use a secrets manager (Vault, AWS Secrets Manager, etc.)
#
# 3. Never commit actual credentials - use .env.example templates
#
# 4. Start with: docker-compose up -d
#    Or locally:  ./scripts/setup.sh

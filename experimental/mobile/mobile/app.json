{
  "expo": {
    "name": "Infra Pilot",
    "slug": "infra-pilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "infrapilot",
    "splash": {
      "backgroundColor": "#0B0720"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cosmicinfra.pilot",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely log in to Infra Pilot"
      }
    },
    "android": {
      "package": "com.cosmicinfra.pilot",
      "adaptiveIcon": {
        "backgroundColor": "#0B0720"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

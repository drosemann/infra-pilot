# Discord Bot Token (Required)
DISCORD_TOKEN=your_discord_bot_token_here

# Pterodactyl API (Required)
PTERODACTYL_API_URL=https://your.pterodactyl.domain
PTERODACTYL_API_KEY=your_pterodactyl_api_key_here

# Discord channels & roles
SERVER_CREATION_CHANNEL_ID=your_channel_id_here
SERVER_CREATOR_ROLE_ID=your_role_id_here
WORKFLOW_NOTIFICATION_CHANNEL_ID=your_channel_id_here
SESSION_ALERT_CHANNEL_ID=your_channel_id_here
COMPLIANCE_ALERT_CHANNEL_ID=your_channel_id_here

# Limits
MAX_SERVERS_PER_USER=1

# Pterodactyl Egg IDs
MINECRAFT_EGG_ID=1
NODEJS_EGG_ID=2
TEAMSPEAK_EGG_ID=3
DATABASE_EGG_ID=4
PYTHON_EGG_ID=5

# Deploy location
LOCATION_ID=1

# Database (used by stats, economy, dashboard modules)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=infra_pilot

# Disable the service without removing config
DISCORD_SERVICE_DISABLED=false

# Code Review / AI features
CODE_REVIEW_WEBHOOK_PORT=3000
CODE_REVIEW_WEBHOOK_SECRET=default-secret
AI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4
GITHUB_TOKEN=

# Integration service URL
INTEGRATION_SERVICE_URL=http://localhost:9000

# Reporting API base
API_BASE_URL=http://localhost:3001

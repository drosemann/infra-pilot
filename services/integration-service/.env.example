# Integration Service - Environment Configuration
# Copy to .env and configure

# Service URLs
DASHBOARD_URL=http://localhost:5173
DISCORD_API_URL=http://localhost:3000
SERVICE_CORE_URL=http://localhost:8080
ORCHESTRATOR_URL=http://localhost:8500

# PostgreSQL
DATABASE_URL=postgresql://infra_pilot:infra_pilot_dev_password@localhost:5432/infra_pilot

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret (must match management-panel)
JWT_SECRET=your_jwt_secret_key_here

# Port
INTEGRATION_API_PORT=9000

# Webhook Secrets
WEBHOOK_SECRET=change-me-webhook-secret
IPAAS_WEBHOOK_SECRET=change-me-ipaas-secret
SECRETS_ENCRYPTION_KEY=

# HashiCorp Vault (optional)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Prometheus
PROMETHEUS_PORT=9090

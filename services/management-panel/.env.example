# Management Panel - Environment Configuration
# Copy to .env.local for local development

# Backend
PORT=3001
NODE_ENV=development

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
VITE_ENVIRONMENT=development
VITE_DEMO_FEATURE_ENABLED=false

# Supabase (optional - for hosted features)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=local-dev-anon-key

# PostgreSQL
DATABASE_URL=postgresql://infra_pilot:infra_pilot_dev_password@localhost:5432/infra_pilot

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Service URLs
INTEGRATION_SERVICE_URL=http://localhost:9000

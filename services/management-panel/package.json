{
  "name": "docker-panel",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite --open",
    "dev:backend": "TS_NODE_TRANSPILE_ONLY=true TS_NODE_COMPILER_OPTIONS='{\"module\":\"ESNext\",\"moduleResolution\":\"bundler\",\"allowImportingTsExtensions\":true}' node --loader ts-node/esm server/index.ts",
    "build": "vite build",
    "lint": "tsc --noEmit --pretty false",
    "preview": "vite preview",
    "test:playwright": "npx playwright test --config playwright.config.ts",
    "playwright:install": "npx playwright install",
    "seed:customers": "node ./scripts/seed-customers.mjs",
    "test": "NODE_ENV=test TS_NODE_TRANSPILE_ONLY=true TS_NODE_COMPILER_OPTIONS='{\"module\":\"ESNext\",\"moduleResolution\":\"bundler\",\"allowImportingTsExtensions\":true}' node --test --loader ts-node/esm tests/**/*.test.ts",
    "test:coverage": "NODE_ENV=test TS_NODE_TRANSPILE_ONLY=true TS_NODE_COMPILER_OPTIONS='{\"module\":\"ESNext\",\"moduleResolution\":\"bundler\",\"allowImportingTsExtensions\":true}' NODE_V8_COVERAGE=coverage/v8 node --test --experimental-test-coverage --loader ts-node/esm tests/**/*.test.ts",
    "test:api": "NODE_ENV=test TS_NODE_TRANSPILE_ONLY=true TS_NODE_COMPILER_OPTIONS='{\"module\":\"ESNext\",\"moduleResolution\":\"bundler\",\"allowImportingTsExtensions\":true}' node --test --loader ts-node/esm tests/integration/**/*.test.ts",
    "test:unit": "NODE_ENV=test TS_NODE_TRANSPILE_ONLY=true TS_NODE_COMPILER_OPTIONS='{\"module\":\"ESNext\",\"moduleResolution\":\"bundler\",\"allowImportingTsExtensions\":true}' node --test --loader ts-node/esm tests/unit/**/*.test.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "desktop:dev": "zig build dev",
    "desktop:run": "zig build run",
    "desktop:package": "zig build package",
    "desktop:validate": "zero-native validate app.zon",
    "desktop:doctor": "zero-native doctor --manifest app.zon --strict"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.5",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "axios": "^1.17.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "effect": "^3.13.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jdenticon": "^3.3.0",
    "pg": "^8.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.7",
    "react-intl": "^10.1.13",
    "react-router-dom": "^6.30.4",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "~10",
    "dotenv": "^16.4.7",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.15.0",
    "playwright": "^1.60.0",
    "postcss": "~8",
    "prettier": "^3.5.3",
    "tailwindcss": "~3",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2.0"
  }
}

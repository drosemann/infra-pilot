# Orchestrator Agent - Environment Configuration
# Copy to .env and configure

# Discord Bot Token (used by orchestrator agent)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# PostgreSQL Database
DATABASE_URL=postgresql://infra_pilot:infra_pilot_dev_password@localhost:5432/infra_pilot
DB_HOST=localhost
DB_PORT=5432
DB_USER=infra_pilot
DB_PASSWORD=infra_pilot_dev_password
DB_NAME=infra_pilot

# Redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Webhook
GITOPS_WEBHOOK_PORT=8500

# Docker / Container Registry
REGISTRY=ghcr.io
IMAGE_TAG=latest

# Server Limits
SERVER_LIMIT=1
RAM_LIMIT=1g
DEFAULT_IMAGE=ubuntu-22.04-with-tmate

# Disable service
ORCHESTRATOR_AGENT_DISABLED=true
